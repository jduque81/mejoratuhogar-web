# ─── Sanity CMS ───────────────────────────────────────────────────────────────
# Found in sanity.io → project → settings
SANITY_PROJECT_ID=your_project_id_here
SANITY_DATASET=production

# ─── Analytics ────────────────────────────────────────────────────────────────
# Google Analytics 4 measurement ID
PUBLIC_GA_ID=G-XXXXXXXXXX

# ─── Form submission ──────────────────────────────────────────────────────────
# Endpoint for ContactForm submissions.
# Leave blank to use Netlify Forms (data-netlify="true" handles it automatically).
# Set to a Formspree URL if not deploying on Netlify:
#   PUBLIC_FORM_ACTION=https://formspree.io/f/your_form_id
# When unset, forms show an inline success message (demo mode).
PUBLIC_FORM_ACTION=
