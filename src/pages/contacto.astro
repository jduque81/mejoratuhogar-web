---
/**
 * contacto.astro — Contact page (/contacto)
 *
 * Fully static. No CMS data needed.
 *
 * Sections:
 *   1. Page header — simple heading + subtitle
 *   2. 2-column: ContactForm (contact variant) + contact info panel
 *   3. Zone coverage strip
 *   4. Final CTA — WhatsApp
 */

import BaseLayout from '../layouts/BaseLayout.astro'
import ContactForm from '../components/ContactForm.astro'
import CTABlock from '../components/CTABlock.astro'
import WhatsAppButton from '../components/WhatsAppButton.astro'
import { SITE } from '../data/site'
---

<BaseLayout
  title="Contacto – Mejora Tu Hogar | Benicarló y Castellón"
  description="Contacta con Mejora Tu Hogar en Benicarló. Teléfono, WhatsApp, email y formulario de contacto. Atendemos Benicarló, Vinaròs, Peñíscola y Castellón."
  whatsappContext="contact"
>

  <!-- ─── 1. Page header ──────────────────────────────────────────────── -->
  <section class="py-12 md:py-16 bg-gray-50 border-b border-gray-100">
    <div class="container max-w-4xl mx-auto text-center">
      <h1 class="font-heading font-bold text-3xl md:text-4xl text-brand-black mb-3">
        ¿Cómo podemos ayudarte?
      </h1>
      <p class="text-gray-600 text-lg max-w-xl mx-auto">
        Estamos en Benicarló y respondemos rápido. Escríbenos, llámanos o rellena el formulario.
      </p>
    </div>
  </section>

  <!-- ─── 2. Form + contact info ─────────────────────────────────────── -->
  <section class="py-16 md:py-20 bg-brand-white" aria-labelledby="contact-form-heading">
    <div class="container max-w-5xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-start">

        <!-- Contact form -->
        <div>
          <h2 id="contact-form-heading" class="font-heading font-bold text-2xl text-brand-black mb-2">
            Envíanos un mensaje
          </h2>
          <p class="text-gray-600 mb-6">Te respondemos en menos de 24 horas en días laborables.</p>
          <ContactForm
            formId="contact-page-form"
            variant="contact"
            submitLabel="Enviar mensaje"
            whatsappContext="contact"
          />
        </div>

        <!-- Contact info panel -->
        <div class="flex flex-col gap-4">

          <!-- Phone -->
          <div class="flex items-start gap-4 p-5 bg-gray-50 rounded-2xl border border-gray-100">
            <div class="flex items-center justify-center w-10 h-10 rounded-full bg-green-50 shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#2E7D32" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.67A2 2 0 012 1h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 14.92z"/>
              </svg>
            </div>
            <div>
              <p class="text-xs text-gray-500 font-medium mb-1 uppercase tracking-wide">Teléfono</p>
              <a
                href={`tel:${SITE.phone.replace(/\s/g, '')}`}
                class="font-heading font-bold text-brand-black text-lg hover:text-brand-green transition-colors"
              >
                {SITE.phone}
              </a>
              <p class="text-xs text-gray-500 mt-1">Lunes a viernes, 9:00 – 19:00</p>
            </div>
          </div>

          <!-- WhatsApp -->
          <div class="flex items-start gap-4 p-5 bg-gray-50 rounded-2xl border border-gray-100">
            <div class="flex items-center justify-center w-10 h-10 rounded-full bg-[#e8faf0] shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="#25D366" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </div>
            <div class="flex flex-col gap-2">
              <p class="text-xs text-gray-500 font-medium uppercase tracking-wide">WhatsApp</p>
              <WhatsAppButton variant="inline" context="contact" />
              <p class="text-xs text-gray-500">Respuesta en minutos</p>
            </div>
          </div>

          <!-- Email -->
          <div class="flex items-start gap-4 p-5 bg-gray-50 rounded-2xl border border-gray-100">
            <div class="flex items-center justify-center w-10 h-10 rounded-full bg-green-50 shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#2E7D32" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </div>
            <div>
              <p class="text-xs text-gray-500 font-medium mb-1 uppercase tracking-wide">Email</p>
              <a
                href={`mailto:${SITE.email}`}
                class="font-medium text-brand-black hover:text-brand-green transition-colors"
              >
                {SITE.email}
              </a>
            </div>
          </div>

          <!-- Zone coverage -->
          <div class="flex items-start gap-4 p-5 bg-gray-50 rounded-2xl border border-gray-100">
            <div class="flex items-center justify-center w-10 h-10 rounded-full bg-green-50 shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#2E7D32" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <div>
              <p class="text-xs text-gray-500 font-medium mb-1 uppercase tracking-wide">Zona de trabajo</p>
              <p class="font-medium text-brand-black">Benicarló, Vinaròs y Peñíscola</p>
              <p class="text-sm text-gray-500 mt-1">
                También atendemos Castellón y Tarragona
              </p>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- ─── 3. Zone coverage strip ─────────────────────────────────────── -->
  <section class="py-10 bg-gray-50 border-t border-b border-gray-100" aria-label="Municipios donde trabajamos">
    <div class="container max-w-5xl mx-auto">
      <p class="text-center text-sm text-gray-500 mb-5 font-medium">Zonas de actuación principales y secundarias</p>
      <div class="flex flex-wrap justify-center gap-2">
        {[
          { label: 'Benicarló', primary: true },
          { label: 'Vinaròs', primary: true },
          { label: 'Peñíscola', primary: true },
          { label: 'Castellón', primary: false },
          { label: 'Tarragona', primary: false },
          { label: 'Alcalà de Xivert', primary: false },
          { label: 'Càlig', primary: false },
          { label: 'Traiguera', primary: false },
          { label: 'Sant Jordi', primary: false },
        ].map((zone) => (
          <span class={`px-4 py-1.5 rounded-full text-sm font-medium border ${zone.primary ? 'bg-green-50 border-green-200 text-brand-green font-semibold' : 'bg-white border-gray-200 text-gray-600'}`}>
            {zone.label}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── 4. Final CTA ────────────────────────────────────────────────── -->
  <CTABlock
    title="¿Prefieres que te llamemos nosotros?"
    subtitle="Déjanos tu número en el formulario y te llamamos en menos de 24 horas. Sin compromiso."
    ctaPrimary={{ label: 'Rellenar formulario', href: '#contact-form-heading' }}
    ctaWhatsApp={{ label: 'Escribir por WhatsApp', context: 'contact' }}
    variant="light"
  />

</BaseLayout>
