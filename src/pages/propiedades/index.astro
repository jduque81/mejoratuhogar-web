----
import BaseLayout from '../../layouts/BaseLayout.astro'
import { sanityClient } from '../../lib/sanity'

const properties = await sanityClient.fetch(`
  *[_type == "property"]{
    _id,
    title,
    price,
    location,
    "imageUrl": mainImage.asset->url
  }
`)
---

<BaseLayout
  title="Propiedades en Castellón – Compra y Alquiler"
  description="Explora todas las propiedades disponibles en Castellón. Pisos, casas y áticos en venta y alquiler."
>
  <section class="container py-30 text-center">
    <h1 class="font-heading text-4xl font-bold text-brand-black mb-4">
      Propiedades
    </h1>
    {
  properties.length === 0 ? (
    <p>No hay propiedades aún.</p>
  ) : (
    <div class="grid gap-6 mt-8">
      {properties.map((property) => (
        <div class="border p-4 rounded-xl">
          {property.imageUrl && (
            <img src={property.imageUrl} alt={property.title} class="w-full h-48 object-cover rounded-lg mb-4" />
          )}
          <h2 class="text-xl font-bold">{property.title}</h2>
          <p>{property.location}</p>
          <p class="font-semibold">{property.price} €</p>
        </div>
      ))}
    </div>
  )
  }
</section>
</BaseLayout>
