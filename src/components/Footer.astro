---
/**
 * Footer.astro — Site footer
 *
 * No props — all data from SITE.
 * Three-column layout (stacks to single column on mobile).
 * Includes: brand, service links, contact, legal row.
 */

import { SITE } from '../data/site'

const currentYear = new Date().getFullYear()

const serviceLinks = [
  { label: 'Comprar vivienda', href: '/comprar' },
  { label: 'Vender vivienda', href: '/vender' },
  { label: 'Alquiler', href: '/alquiler' },
  { label: 'Ventanas y puertas PVC', href: '/ventanas-pvc' },
  { label: 'Nuestras zonas', href: '/zonas/benicarlo' },
]

const companyLinks = [
  { label: 'Sobre nosotros', href: '/sobre-nosotros' },
  { label: 'Contacto', href: '/contacto' },
]
---

<footer class="bg-brand-black text-white">
  <!-- ─── Main footer grid ──────────────────────────────────────────────── -->
  <div class="container max-w-6xl mx-auto py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-8">

      <!-- Col 1: Brand + tagline + contact -->
      <div class="flex flex-col gap-4">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2 w-fit" aria-label="Mejora Tu Hogar – Inicio">
          <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-brand-green text-white font-heading font-bold text-lg" aria-hidden="true">M</span>
          <span class="font-heading font-bold text-white text-lg">Mejora Tu Hogar</span>
        </a>

        <p class="text-gray-400 text-sm leading-relaxed max-w-xs">
          Inmobiliaria local en Castellón. Compra, vende, alquila y mejora tu hogar con nosotros.
        </p>

        <!-- Contact details -->
        <div class="flex flex-col gap-2 mt-2">
          <a
            href={`tel:${SITE.phone.replace(/\s/g, '')}`}
            class="flex items-center gap-2 text-sm text-gray-300 hover:text-white transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.67A2 2 0 012 1h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 14.92z"/>
            </svg>
            {SITE.phone}
          </a>

          <a
            href={`mailto:${SITE.email}`}
            class="flex items-center gap-2 text-sm text-gray-300 hover:text-white transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="4" width="20" height="16" rx="2"/>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 01-2.06 0L2 7"/>
            </svg>
            {SITE.email}
          </a>

          <span class="flex items-center gap-2 text-sm text-gray-400">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0116 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            {SITE.address}
          </span>
        </div>
      </div>

      <!-- Col 2: Services -->
      <div>
        <h3 class="font-heading font-semibold text-white text-sm uppercase tracking-wider mb-4">
          Servicios
        </h3>
        <ul class="flex flex-col gap-2">
          {serviceLinks.map(({ label, href }) => (
            <li>
              <a href={href} class="text-sm text-gray-400 hover:text-white transition-colors">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 3: Company -->
      <div>
        <h3 class="font-heading font-semibold text-white text-sm uppercase tracking-wider mb-4">
          Empresa
        </h3>
        <ul class="flex flex-col gap-2 mb-6">
          {companyLinks.map(({ label, href }) => (
            <li>
              <a href={href} class="text-sm text-gray-400 hover:text-white transition-colors">
                {label}
              </a>
            </li>
          ))}
        </ul>

        <!-- WhatsApp CTA -->
        <a
          href={`https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent(SITE.whatsappMessages.default)}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-sm font-semibold transition-opacity hover:opacity-80"
          style="color: #25D366;"
          onclick="window.trackWhatsApp && window.trackWhatsApp('default')"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Escríbenos por WhatsApp
        </a>
      </div>

    </div>
  </div>

  <!-- ─── Legal bar ──────────────────────────────────────────────────────── -->
  <div class="border-t border-gray-800">
    <div class="container max-w-6xl mx-auto py-4">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-2 text-xs text-gray-500">
        <span>© {currentYear} {SITE.fullName}. Todos los derechos reservados.</span>
        <div class="flex items-center gap-4">
          <a href="/aviso-legal" class="hover:text-gray-300 transition-colors">Aviso legal</a>
          <a href="/privacidad" class="hover:text-gray-300 transition-colors">Privacidad</a>
          <a href="/cookies" class="hover:text-gray-300 transition-colors">Cookies</a>
        </div>
      </div>
    </div>
  </div>
</footer>
