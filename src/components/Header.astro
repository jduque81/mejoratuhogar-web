---
/**
 * Header.astro — Site navigation
 *
 * No props — pulls business data from SITE.
 * Uses Astro.url.pathname to highlight the active nav link.
 *
 * Layout:
 *   Mobile:  Logo | hamburger button
 *            → full-width mobile menu (JS toggle)
 *   Desktop: Logo | nav links | phone + WhatsApp CTA
 */

import { SITE } from '../data/site'

const currentPath = Astro.url.pathname

const navLinks = [
  { label: 'Comprar', href: '/comprar' },
  { label: 'Vender', href: '/vender' },
  { label: 'Alquiler', href: '/alquiler' },
  { label: 'Ventanas y puertas PVC', href: '/ventanas-pvc' },
  { label: 'Contacto', href: '/contacto' },
]

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/'
  return currentPath.startsWith(href)
}
---

<header class="sticky top-0 z-40 bg-brand-white border-b border-gray-100 shadow-sm">
  <div class="container max-w-6xl mx-auto">
    <div class="flex items-center justify-between h-16 md:h-18">

      <!-- ─── Logo ─────────────────────────────────────────────────────────── -->
      <a href="/" class="flex items-center gap-2 shrink-0" aria-label="Mejora Tu Hogar – Inicio">
        <span
          class="flex items-center justify-center w-8 h-8 rounded-lg bg-brand-green text-white font-heading font-bold text-lg"
          aria-hidden="true"
        >M</span>
        <span class="font-heading font-bold text-brand-black text-lg leading-none">
          Mejora Tu Hogar
        </span>
      </a>

      <!-- ─── Desktop nav ───────────────────────────────────────────────────── -->
      <nav class="hidden lg:flex items-center gap-1" aria-label="Navegación principal">
        {navLinks.map(({ label, href }) => (
          <a
            href={href}
            class={`px-3 py-2 rounded-md text-sm font-medium transition-colors
              ${isActive(href)
                ? 'text-brand-green font-semibold'
                : 'text-gray-600 hover:text-brand-black hover:bg-gray-50'
              }`}
            aria-current={isActive(href) ? 'page' : undefined}
          >
            {label}
          </a>
        ))}
      </nav>

      <!-- ─── Desktop CTA row ───────────────────────────────────────────────── -->
      <div class="hidden lg:flex items-center gap-3">
        <!-- Phone -->
        <a
          href={`tel:${SITE.phone.replace(/\s/g, '')}`}
          class="flex items-center gap-1.5 text-sm font-medium text-gray-700 hover:text-brand-black transition-colors"
          aria-label={`Llamar al ${SITE.phone}`}
        >
          <!-- Phone icon -->
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.67A2 2 0 012 1h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 14.92z"/>
          </svg>
          {SITE.phone}
        </a>

        <!-- WhatsApp CTA -->
        <a
          href={`https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent(SITE.whatsappMessages.default)}`}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary py-2 px-4 text-sm"
          onclick="window.trackWhatsApp && window.trackWhatsApp('default')"
        >
          Escríbenos
        </a>
      </div>

      <!-- ─── Mobile: phone link + hamburger ──────────────────────────────── -->
      <div class="flex items-center gap-3 lg:hidden">
        <a
          href={`tel:${SITE.phone.replace(/\s/g, '')}`}
          class="flex items-center justify-center w-9 h-9 rounded-lg text-gray-700 hover:bg-gray-100 transition-colors"
          aria-label={`Llamar al ${SITE.phone}`}
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.67A2 2 0 012 1h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 14.92z"/>
          </svg>
        </a>

        <button
          id="nav-toggle"
          type="button"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Abrir menú"
          class="flex items-center justify-center w-9 h-9 rounded-lg text-gray-700 hover:bg-gray-100 transition-colors"
        >
          <!-- Hamburger icon (shown when closed) -->
          <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
          <!-- Close icon (shown when open) -->
          <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="hidden">
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>

    </div><!-- end flex row -->

    <!-- ─── Mobile menu (hidden by default) ─────────────────────────────── -->
    <nav
      id="mobile-menu"
      class="hidden lg:hidden border-t border-gray-100 pb-4"
      aria-label="Navegación móvil"
    >
      <ul class="flex flex-col gap-1 pt-2">
        {navLinks.map(({ label, href }) => (
          <li>
            <a
              href={href}
              class={`flex items-center px-3 py-2.5 rounded-md text-base font-medium transition-colors
                ${isActive(href)
                  ? 'text-brand-green bg-green-50 font-semibold'
                  : 'text-gray-700 hover:text-brand-black hover:bg-gray-50'
                }`}
              aria-current={isActive(href) ? 'page' : undefined}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

  </div><!-- end container -->
</header>

<script>
  const toggle = document.getElementById('nav-toggle')
  const menu = document.getElementById('mobile-menu')
  const iconOpen = document.getElementById('icon-open')
  const iconClose = document.getElementById('icon-close')

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true'
    const next = !isOpen

    toggle.setAttribute('aria-expanded', String(next))
    toggle.setAttribute('aria-label', next ? 'Cerrar menú' : 'Abrir menú')
    menu?.classList.toggle('hidden', !next)
    iconOpen?.classList.toggle('hidden', next)
    iconClose?.classList.toggle('hidden', !next)
  })

  // Close menu when a link is clicked
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      toggle?.setAttribute('aria-expanded', 'false')
      toggle?.setAttribute('aria-label', 'Abrir menú')
      menu.classList.add('hidden')
      iconOpen?.classList.remove('hidden')
      iconClose?.classList.add('hidden')
    })
  })
</script>
