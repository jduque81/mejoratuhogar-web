---
/**
 * PropertyCard.astro — Property listing card
 *
 * Props:
 *   property — PropertyCard type from src/lib/sanity.ts (required)
 *
 * Displays: image, operation type badge, status badge (if not available),
 * price, city, property type, key stats (beds / baths / area), CTA.
 */

import type { PropertyCard as PropertyCardData } from '../lib/sanity'
import { sanityImageUrl } from '../utils/image'
import { formatPrice, formatArea, PROPERTY_TYPE_LABELS, OPERATION_TYPE_LABELS, STATUS_CONFIG } from '../utils/format'

interface Props {
  property: PropertyCardData
}

const { property } = Astro.props

const {
  title,
  slug,
  operationType,
  status,
  price,
  city,
  propertyType,
  bedrooms,
  bathrooms,
  builtArea,
  featuredImage,
  shortDescription,
} = property

const imageUrl = sanityImageUrl(featuredImage, { width: 600, height: 400 })
const href = `/propiedades/${slug.current}`
const isRent = operationType === 'rent'
const isAvailable = status === 'available'
const statusCfg = STATUS_CONFIG[status] ?? STATUS_CONFIG.available
const operationLabel = OPERATION_TYPE_LABELS[operationType] ?? operationType
const typeLabel = PROPERTY_TYPE_LABELS[propertyType] ?? propertyType
---

<a
  href={href}
  class="group flex flex-col bg-white rounded-2xl border border-gray-200 overflow-hidden
         transition-all duration-200 hover:shadow-md hover:-translate-y-0.5"
  aria-label={`Ver propiedad: ${title}`}
>
  <!-- ─── Image ────────────────────────────────────────────────────────── -->
  <div class="relative aspect-[4/3] overflow-hidden bg-gray-100">
    <img
      src={imageUrl}
      alt={featuredImage?.alt ?? title}
      class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
      loading="lazy"
      decoding="async"
      width="600"
      height="400"
    />

    <!-- Operation type badge (Venta / Alquiler) -->
    <span class={`absolute top-3 left-3 px-2.5 py-1 rounded-full text-xs font-semibold
      ${isRent
        ? 'bg-blue-600 text-white'
        : 'bg-brand-green text-white'
      }`}>
      {operationLabel}
    </span>

    <!-- Status badge (only when not available) -->
    {!isAvailable && (
      <span class={`absolute top-3 right-3 px-2.5 py-1 rounded-full text-xs font-semibold ${statusCfg.color}`}>
        {statusCfg.label}
      </span>
    )}
  </div>

  <!-- ─── Content ──────────────────────────────────────────────────────── -->
  <div class="flex flex-col gap-3 p-5 flex-1">

    <!-- Price + type -->
    <div class="flex items-start justify-between gap-2">
      <span class="font-heading font-bold text-brand-black text-xl leading-none">
        {formatPrice(price, isRent)}
      </span>
      <span class="text-xs text-gray-500 font-medium bg-gray-100 px-2 py-0.5 rounded-full shrink-0">
        {typeLabel}
      </span>
    </div>

    <!-- Title -->
    <h3 class="font-heading font-semibold text-brand-black text-base leading-snug line-clamp-2 group-hover:text-brand-green transition-colors">
      {title}
    </h3>

    <!-- Location -->
    {city?.name && (
      <div class="flex items-center gap-1.5 text-sm text-gray-500">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0116 0z"/>
          <circle cx="12" cy="10" r="3"/>
        </svg>
        {city.name}
      </div>
    )}

    <!-- Short description -->
    {shortDescription && (
      <p class="text-sm text-gray-600 line-clamp-2 leading-relaxed">
        {shortDescription}
      </p>
    )}

    <!-- ─── Stats row ───────────────────────────────────────────────────── -->
    {(bedrooms || bathrooms || builtArea) && (
      <div class="flex items-center gap-4 pt-2 border-t border-gray-100 text-sm text-gray-600">

        {bedrooms && (
          <span class="flex items-center gap-1.5">
            <!-- Bed icon -->
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M2 9V4a2 2 0 012-2h16a2 2 0 012 2v5"/>
              <path d="M2 11v5a2 2 0 002 2h16a2 2 0 002-2v-5a2 2 0 00-4 0v2H6v-2a2 2 0 00-4 0z"/>
            </svg>
            <span>{bedrooms}</span>
          </span>
        )}

        {bathrooms && (
          <span class="flex items-center gap-1.5">
            <!-- Droplet icon for bathrooms -->
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 22a7 7 0 007-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5C6 11.1 5 13 5 15a7 7 0 007 7z"/>
            </svg>
            <span>{bathrooms}</span>
          </span>
        )}

        {builtArea && (
          <span class="flex items-center gap-1.5">
            <!-- Area icon -->
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
            </svg>
            <span>{formatArea(builtArea)}</span>
          </span>
        )}

      </div>
    )}

  </div>

  <!-- ─── Card footer CTA ───────────────────────────────────────────────── -->
  <div class="px-5 pb-5">
    <span class="block w-full text-center py-2.5 rounded-lg border border-gray-200 text-sm font-semibold text-brand-black transition-colors group-hover:bg-brand-green group-hover:border-brand-green group-hover:text-white">
      Ver propiedad
    </span>
  </div>

</a>
